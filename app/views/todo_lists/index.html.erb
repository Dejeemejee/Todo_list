<div id="todo_lists-index-page" class="todo_lists-index-page">
    <h1>Your intuitive and simple Todo List app</h1>

    <%= link_to 'Create New Task', new_todo_list_path, class: "btn" %>

    <% if @todo_list.empty? %>
     <p id="para">No tasks found. Start by creating a new task!</p>
    <% end %>
    
    <ul class="index todo_lists">
       <% @todo_list.each do |todo_list| %>

      <li><div><%= link_to todo_list.title, todo_list, class: "title" %></div><div class= "description"><%= todo_list.description %></div>
      <div class="due_date"><%= todo_list.due_date.strftime("%B %d, %Y") if todo_list.due_date %></div>
      <div class="created_at"><%= todo_list.created_at.strftime("%B %d, %Y") if todo_list.created_at %></div>
      <div class="actions">
        <%= link_to 'Edit', edit_todo_list_path(todo_list), class: "edit-btn" %>
        <%= link_to 'Delete', todo_list_path(todo_list), method: :delete, data: {turbo_method: :delete, turbo_confirm: 'Are you sure you want to delete?' }, class: "delete-btn" %>
          
      </li>
    
      <%end %>
    </ul>

</div>
