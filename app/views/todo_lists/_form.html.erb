<%= form_with model: @todo_list do |form| %>

<div>
    <%= form.label :title %><br>
    <%= form.text_field :title %>
    <% if @todo_list.errors[:title].any? %>
      <div class="error"><%= @todo_list.errors[:title].join(", ") %></div>
    <% end %>
</div>

<div>
    <%= form.label :description %><br>
    <%= form.text_area :description %>
    <% if @todo_list.errors[:description].any? %>
      <div class="error"><%= @todo_list.errors[:description].join(", ") %></div>
    <% end %>
</div>

 <div>
    <%= form.label :due_date %>
    <%= form.date_field :due_date %>
    <% if @todo_list.errors[:due_date].any? %>
      <div class="error"><%= @todo_list.errors[:due_date].join(", ") %></div>
    <% end %>
  </div>

 
  <div>
     <%= form.label :created_at %>
     <%= form.text_field :created_at, value: Time.now, readonly: true %>
        <% if @todo_list.errors[:created_at].any? %>
        <div class="error"><%= @todo_list.errors[:created_at].join(", ") %></div>
      <% end %>
  </div>

<div>
    <%= form.submit %>
</div>
<% end %>